{%- set postslistIndex = postslist.length + 1 %}
{%- for year, posts in postslist | groupby("data.year") | dictsort | reverse %}
<h3>{{ year }}</h3>
<ol reversed class="postlist" style="--postlist-index: {{ postslistIndex }}">
{%- for post in posts | reverse %}
	<li class="postlist-item{% if post.url == url %} postlist-item-active{% endif %}">
		<a href="{{ post.url }}" class="postlist-link">{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}</a>
		<time class="postlist-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate("LLLL dd, yyyy") }}</time>
	</li>
{%- endfor %}
</ol>
{%- set postslistIndex = postslistIndex - posts.length %}
{%- endfor %}
